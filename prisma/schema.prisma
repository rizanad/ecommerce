generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  // Adding the '?' makes it optional, so existing rows can be null
  description String?  @db.Text 
  price       Float    
  imageUrl    String?
  category    String
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  // Adding a default now() allows existing rows to have a value
  updatedAt   DateTime @default(now()) @updatedAt

  reviews     Review[]
}

model Review {
  id          Int      @id @default(autoincrement())
  rating      Int      // 1-5 stars
  comment     String   @db.Text
  productId   Int
  // Cascade means if you delete a product, its reviews are deleted too
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}